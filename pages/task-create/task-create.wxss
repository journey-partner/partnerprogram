/* 任务创建 - 全部使用语义化变量 */

.page-container {
  min-height: 100vh;
  background: var(--color-bg);
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  overflow-y: auto;
}

/* 区块 */
.form-section {
  margin: var(--space-lg) var(--space-xl);
}
.card.form-card {
  padding: var(--space-xl);
  margin-bottom: var(--space-lg);
}
.form-label {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-text-secondary);
  display: flex;
  align-items: center;
  gap: 6rpx;
  margin-bottom: var(--space-lg);
  line-height: 1.5;
}

/* 输入框外层包裹 - 统一间距 */
.form-input-wrap {
  background: var(--color-bg-secondary);
  border-radius: var(--radius-md);
  padding: var(--space-md) var(--space-lg);
}

/* 卡片内 input 覆写：去掉底部 border，由外层容器承载 */
.form-card .input {
  border-bottom: none;
  padding: 0;
  font-size: 28rpx;
  line-height: 1.6;
}

/* 计划时间 */
.date-row {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
}
.date-item {
  flex: 1;
}
.date-label {
  font-size: 24rpx;
  color: var(--color-text-muted);
  display: block;
  margin-bottom: 8rpx;
}
.date-sep {
  font-size: 24rpx;
  color: var(--color-text-muted);
  margin-top: 28rpx;
}
.date-picker-box {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--space-md) var(--space-lg);
  background: var(--color-bg-secondary);
  border-radius: var(--radius-md);
  border: 1rpx solid var(--color-border-light);
}
.date-picker-text {
  font-size: 28rpx;
  color: var(--color-text-primary);
}
.date-picker-placeholder {
  font-size: 28rpx;
  color: var(--color-text-muted);
}

/* 打卡周期选择 */
.checkin-type-row {
  display: flex;
  gap: var(--space-sm);
  margin-bottom: var(--space-lg);
}
.checkin-type-item {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  background: var(--color-bg-secondary);
  border-radius: var(--radius-md);
  border: 2rpx solid transparent;
  transition: all 0.2s;
}
.checkin-type-active {
  background: var(--color-primary-bg);
  border-color: var(--color-primary);
  color: var(--color-primary-dark);
  font-weight: 600;
}

/* 每周选择 */
.weekly-section {
  max-height: 0;
  overflow: hidden;
  opacity: 0;
  transition: all 0.3s;
}
.weekly-section.show {
  max-height: 300rpx;
  opacity: 1;
  margin-bottom: var(--space-md);
}
.weekly-label {
  font-size: 24rpx;
  color: var(--color-text-muted);
  display: block;
  margin-bottom: var(--space-sm);
}
.weekday-selector {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-sm);
}
.weekday-chip {
  padding: 12rpx 24rpx;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  background: var(--color-bg-secondary);
  border-radius: var(--radius-full);
  border: 2rpx solid transparent;
  transition: all 0.2s;
}
.weekday-chip-active {
  background: var(--color-primary);
  color: var(--color-text-inverse);
  border-color: var(--color-primary);
}

/* 开关行 */
.switch-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 0;
}
.switch-info { flex: 1; }
.switch-label {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  display: block;
  margin-bottom: 4rpx;
}
.switch-desc {
  font-size: 24rpx;
  color: var(--color-text-muted);
}

/* 提醒时间 */
.reminder-section {
  max-height: 0;
  overflow: hidden;
  opacity: 0;
  transition: all 0.3s;
  margin-top: 0;
}
.reminder-section.show {
  max-height: 120rpx;
  margin-top: var(--space-lg);
  opacity: 1;
}
.reminder-box {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--space-lg);
  background: var(--color-primary-bg);
  border-radius: var(--radius-md);
  border: 1rpx solid var(--color-primary-border);
}
.reminder-label {
  font-size: 28rpx;
  color: var(--color-text-secondary);
}
.reminder-time {
  font-size: 28rpx;
  color: var(--color-primary-dark);
  font-weight: 600;
}

/* 鼓励语 */
.encourage-card {
  border: 1rpx solid var(--color-primary-border);
}
.suggest-list {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-sm);
  margin-top: var(--space-md);
}
.suggest-tag {
  font-size: 24rpx;
  color: var(--color-primary-dark);
  background: var(--color-white);
  padding: 10rpx 20rpx;
  border-radius: var(--radius-full);
  border: 1rpx solid var(--color-primary-border);
}
.suggest-tag:active { background: var(--color-primary-bg); }

/* 保存按钮（在 action-bar 内复用 btn） */
.save-btn-inactive {
  background: var(--color-border);
}
.save-btn-active {
  background: var(--color-primary);
  color: var(--color-text-inverse);
  box-shadow: var(--shadow-md);
}
