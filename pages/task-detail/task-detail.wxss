/* 任务详情 - 全部使用语义化变量 */

page {
  overflow-y: auto;
  background: var(--color-bg);
}

.page-container {
  min-height: 100vh;
  padding-bottom: 60rpx;
}

.page-block {
  padding: var(--space-lg) var(--space-xl);
}
.card.detail-card {
  padding: var(--space-xl);
  margin-bottom: var(--space-lg);
}

/* 任务头 */
.task-head-row {
  display: flex;
  align-items: flex-start;
  gap: var(--space-lg);
}
.task-head-info {
  flex: 1;
  min-width: 0;
}
.task-name-big {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  display: block;
  margin-bottom: var(--space-sm);
  line-height: 1.3;
}
.task-name-big.done {
  color: var(--color-text-muted);
  text-decoration: line-through;
}
.meta-row {
  display: flex;
  gap: var(--space-xs);
  flex-wrap: wrap;
}

/* 状态标签 */
.status-tag {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: var(--radius-full);
  font-weight: 500;
}
.status-in_progress {
  background: #dbeafe;
  color: #1d4ed8;
}
.status-not_started {
  background: #f3f4f6;
  color: #6b7280;
}
.status-completed {
  background: #d1fae5;
  color: #065f46;
}
.status-cancelled {
  background: #fee2e2;
  color: #991b1b;
}

/* 计划时间 */
.plan-time-row {
  display: flex;
  align-items: center;
  gap: var(--space-md);
}
.plan-time-item {
  flex: 1;
  background: var(--color-bg-secondary);
  border-radius: var(--radius-md);
  padding: var(--space-md);
  text-align: center;
}
.plan-time-label {
  font-size: 22rpx;
  color: var(--color-text-muted);
  display: block;
  margin-bottom: 4rpx;
}
.plan-time-value {
  font-size: 26rpx;
  color: var(--color-text-primary);
  font-weight: 500;
}
.plan-time-arrow {
  font-size: 28rpx;
  color: var(--color-text-muted);
}

/* 状态管理 */
.status-row {
  display: flex;
  gap: var(--space-sm);
}
.status-btn {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  background: var(--color-bg-secondary);
  border-radius: var(--radius-md);
  border: 2rpx solid transparent;
  transition: all 0.2s;
}
.status-btn-active {
  font-weight: 600;
}
.status-btn-ns.status-btn-active {
  background: #f3f4f6;
  border-color: #9ca3af;
  color: #6b7280;
}
.status-btn-ip.status-btn-active {
  background: #dbeafe;
  border-color: #2563eb;
  color: #1d4ed8;
}
.status-btn-cp.status-btn-active {
  background: #d1fae5;
  border-color: #059669;
  color: #065f46;
}
.status-btn-cl.status-btn-active {
  background: #fee2e2;
  border-color: #dc2626;
  color: #991b1b;
}

/* 描述 */
.detail-text {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  line-height: 1.7;
}

/* 打卡区域 */
.checkin-card {
  border: 1rpx solid var(--color-primary-border);
  background: var(--color-primary-bg);
}
.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--space-lg);
}
.streak-badge {
  font-size: 22rpx;
  color: var(--color-warning);
  background: #fef3c7;
  padding: 6rpx 16rpx;
  border-radius: var(--radius-full);
  font-weight: 500;
}
.checkin-btn-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 56rpx;
  background: var(--color-white);
  border-radius: var(--radius-lg);
  border: 3rpx dashed var(--color-border);
  margin-bottom: var(--space-lg);
  transition: all 0.2s;
}
.checkin-btn-box:active { transform: scale(0.98); }
.checkin-btn-box-done {
  border-style: solid;
  border-color: var(--color-primary);
  background: var(--color-primary-bg);
}
.checkin-btn-icon {
  margin-bottom: var(--space-md);
  display: flex;
  align-items: center;
  justify-content: center;
}
.checkin-btn-text {
  font-size: 30rpx;
  color: var(--color-text-secondary);
  font-weight: 500;
}

/* 鼓励语盒子 */
.encourage-box {
  background: #fefce8;
  border-radius: var(--radius-md);
  padding: var(--space-lg);
  text-align: center;
  margin-bottom: var(--space-lg);
  border: 1rpx solid #fef08a;
}
.encourage-text {
  font-size: 28rpx;
  color: var(--color-warning);
  line-height: 1.6;
}

/* 周进度 */
.week-dots-row {
  display: flex;
  justify-content: space-between;
  margin-top: var(--space-lg);
}
.day-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}
.day-dot {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: var(--color-border);
  transition: all 0.2s;
}
.day-dot-done {
  background: var(--color-primary);
}
.day-dot-none {
  background: transparent;
  border: 1rpx dashed var(--color-border-light);
}
.day-dot-today {
  border: 3rpx solid var(--color-primary);
  background: var(--color-white);
}
.day-label {
  font-size: 22rpx;
  color: var(--color-text-muted);
}

/* 日历 */
.cal-month {
  text-align: center;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: var(--space-lg);
}
.weekday-row {
  display: flex;
  margin-bottom: var(--space-sm);
}
.weekday {
  flex: 1;
  text-align: center;
  font-size: 22rpx;
  color: var(--color-text-muted);
}
.date-grid {
  display: flex;
  flex-wrap: wrap;
}
.date-cell {
  width: calc(100% / 7);
  aspect-ratio: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: var(--color-bg-secondary);
  font-size: 24rpx;
  color: var(--color-text-primary);
  transition: all 0.2s;
}
.date-cell-done {
  background: var(--color-primary);
  color: var(--color-text-inverse);
}
.date-cell-empty {
  background: transparent;
}
.date-cell-today {
  border: 2rpx solid var(--color-primary);
  background: var(--color-white);
}

/* 统计 */
.stats-card {
  background: var(--color-primary-bg);
  border: 1rpx solid var(--color-primary-border);
}
.stats-grid {
  display: flex;
  justify-content: space-around;
}
.stat-item {
  text-align: center;
}
.stat-value {
  font-size: 52rpx;
  font-weight: 700;
  color: var(--color-primary);
  display: block;
  margin-bottom: 4rpx;
}
.stat-label {
  font-size: 24rpx;
  color: var(--color-text-muted);
}

/* 标签 */
.tag-default {
  font-size: 22rpx;
  background: var(--color-bg-secondary);
  color: var(--color-text-muted);
  padding: 4rpx 12rpx;
  border-radius: var(--radius-full);
}
