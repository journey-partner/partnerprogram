<!-- Nav spacer since nav-bar is fixed -->
<view class="nav-spacer"></view>

<view class="page-container">

  <!-- 导航 -->
  <view class="nav-bar">
    <view class="nav-btn-left"></view>
    <text class="nav-title">日志记录</text>
    <view class="nav-btn-right"></view>
  </view>

  <!-- 标签筛选 - 下拉框 -->
  <view class="filter-wrap">
    <picker mode="selector" range="{{filterTags}}" bindchange="onFilterChange" value="{{filterIndex}}">
      <view class="filter-picker">
        <view class="filter-picker-left">
          <icon name="filter" size="32" color="#7c3aed" />
          <text class="filter-picker-text">{{filterTags[filterIndex]}}</text>
        </view>
        <icon name="chevron-down" size="32" color="#9ca3af" />
      </view>
    </picker>
  </view>

  <!-- 引导 -->
  <view class="card guide-card" wx:if="{{logs.length === 0}}" style="margin:32rpx;margin-top:0;">
    <view style="display:flex;align-items:center;gap:12rpx;margin-bottom:24rpx;">
      <icon name="lightbulb" size="44" color="#f59e0b" />
      <text style="font-size:30rpx;font-weight:600;color:#047857">四种日志，四种觉察</text>
    </view>
    <view class="guide-list">
      <view class="guide-item"><view class="guide-tag-icon"><icon name="heart" size="28" color="#ec4899" /></view><text class="guide-item-text">情绪觉察：发现情绪触发点，探索背后的期待和需求</text></view>
      <view class="guide-item"><view class="guide-tag-icon"><icon name="bolt" size="28" color="#f59e0b" /></view><text class="guide-item-text">能量记录：觉察能量起伏，发现滋养和消耗能量的事</text></view>
      <view class="guide-item"><view class="guide-tag-icon"><icon name="hands" size="28" color="#7c3aed" /></view><text class="guide-item-text">感恩日记：每天发现三个以上的感恩事物，培养关注力</text></view>
      <view class="guide-item"><view class="guide-tag-icon"><icon name="trophy" size="28" color="#f59e0b" /></view><text class="guide-item-text">成功记录：肯定自己的每一点进步，培养正向关注力</text></view>
    </view>
  </view>

  <!-- 日志列表 -->
  <view class="log-list" wx:if="{{filteredLogs.length > 0}}">
    <view class="log-group" wx:for="{{groupedLogs}}" wx:key="date">
      <text class="date-header">{{item.date}}</text>
      <view class="card card-elevated log-card" wx:for="{{item.logs}}" wx:for-item="log" wx:key="id" bindtap="goDetail" data-id="{{log.id}}">
        <view class="log-card-head">
          <text class="tag" style="background:{{log.tagColor}}1a;color:{{log.tagColor}}">{{log.tagName}}</text>
          <text class="log-time">{{log.timeStr}}</text>
        </view>
        <text class="log-text">{{log.content}}</text>
        <view class="log-img-row" wx:if="{{log.images && log.images.length > 0}}">
          <image class="log-img" wx:for="{{log.images}}" wx:for-item="img" wx:key="*this" src="{{img}}" mode="aspectFill"></image>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{filteredLogs.length === 0 && logs.length > 0}}">
    <text class="empty-title">暂无此类日志</text>
    <text class="empty-desc">切换标签试试看</text>
  </view>

  <!-- 悬浮按钮 -->
  <view class="fab fab-accent" bindtap="goCreate">
    <view class="fab-icon"><text class="fab-plus">+</text></view>
  </view>

</view>
<!-- custom tab bar -->
<custom-tab-bar />
