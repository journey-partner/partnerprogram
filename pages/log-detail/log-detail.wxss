/* 日志详情 - 全部使用语义化变量 */

page {
  overflow-y: auto;
  background: var(--color-bg);
}

.page-container {
  min-height: 100vh;
  padding-bottom: 60rpx;
}

.page-block {
  padding: var(--space-lg) var(--space-xl);
}

/* 日志内容卡片 */
.log-card {
  margin: var(--space-xl);
  padding: 48rpx 40rpx;
  animation: fadeInUp 0.5s ease;
}

.log-tag-row {
  margin-bottom: var(--space-xl);
}

.log-text-content {
  font-size: 32rpx;
  color: var(--color-text-primary);
  line-height: 2;
  display: block;
  white-space: pre-wrap;
}

/* 图片 */
.log-images {
  margin-top: 40rpx;
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-md);
}
.log-image-wrap {
  width: calc(50% - 8rpx);
  flex: 0 0 auto;
  aspect-ratio: 1;
  position: relative;
}
.log-image {
  width: 100%;
  height: 100%;
  border-radius: var(--radius-md);
  object-fit: cover;
  background: var(--color-bg-secondary);
}
.log-image-error {
  opacity: 0;
}
.log-image-fallback {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  border-radius: var(--radius-md);
  background: var(--color-bg-secondary);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}
.fallback-icon {
  font-size: 48rpx;
  opacity: 0.4;
}
.fallback-text {
  font-size: 22rpx;
  color: var(--color-text-muted);
}

/* 时间 */
.log-time-row {
  margin-top: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--space-md);
  padding-top: var(--space-xl);
  border-top: 1rpx solid var(--color-border-light);
}
.time-icon {
  font-size: 28rpx;
  opacity: 0.5;
}
.time-text {
  font-size: 26rpx;
  color: var(--color-text-muted);
}

/* 操作区 */
.action-row {
  display: flex;
  justify-content: center;
  gap: 80rpx;
  padding: var(--space-2xl) var(--space-xl);
}
.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  transition: transform 0.2s;
}
.action-item:active { transform: scale(0.95); }
.action-circle {
  width: 80rpx;
  height: 80rpx;
  background: var(--color-bg-secondary);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid var(--color-border-light);
}
.action-label {
  font-size: 24rpx;
  color: var(--color-text-muted);
}


