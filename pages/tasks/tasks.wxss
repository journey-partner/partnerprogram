/* 任务管理 - 全部使用语义化变量 */

.page-container {
  min-height: 100vh;
  background: var(--color-bg);
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
}

/* FAB 悬浮按钮 - 提升 z-index 和位置避免与 tab bar 冲突 */
.fab {
  bottom: calc(140rpx + env(safe-area-inset-bottom));
  z-index: 1000;
}

/* 筛选栏 */
.filter-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--space-md) var(--space-xl);
}
.filter-dropdown {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 24rpx;
  background: var(--color-white);
  border-radius: var(--radius-md);
  border: 1rpx solid var(--color-border-light);
  box-shadow: var(--shadow-sm);
}
.filter-text {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}
.filter-arrow {
  font-size: 20rpx;
  color: var(--color-text-muted);
}
.filter-count {
  font-size: 24rpx;
  color: var(--color-text-muted);
}

/* 下拉选项 */
.filter-options {
  margin: 0 var(--space-xl);
  background: var(--color-white);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-lg);
  overflow: hidden;
}
.filter-option {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx var(--space-xl);
  font-size: 28rpx;
  color: var(--color-text-primary);
  border-bottom: 1rpx solid var(--color-border-light);
}
.filter-option:last-child {
  border-bottom: none;
}
.option-active {
  color: var(--color-primary);
  font-weight: 600;
  background: var(--color-primary-bg);
}
.option-count {
  font-size: 24rpx;
  color: var(--color-text-muted);
}
/* 列表 */
.list {
  padding: var(--space-xl);
}
.task-card-item {
  display: flex;
  align-items: center;
  padding: 28rpx;
  margin-bottom: var(--space-md);
  gap: var(--space-md);
}
.task-card-item:active {
  background: var(--color-bg);
}

/* 打卡 */
.task-check {
  width: 44rpx;
  height: 44rpx;
  border: 2rpx solid var(--color-border);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  font-size: 24rpx;
  color: var(--color-text-muted);
  transition: all 0.2s;
}
.task-check-done {
  background: var(--color-primary);
  border-color: var(--color-primary);
  color: var(--color-text-inverse);
}

/* 任务信息 */
.task-info {
  flex: 1;
  min-width: 0;
}
.task-info-head {
  display: flex;
  align-items: center;
  gap: var(--space-xs);
  margin-bottom: 8rpx;
}
.task-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.task-name.done {
  color: var(--color-text-muted);
  text-decoration: line-through;
}

/* 标签行 */
.task-tags {
  display: flex;
  align-items: center;
  gap: 6rpx;
  flex-wrap: wrap;
  margin-bottom: 6rpx;
}

/* 状态标签 */
.status-tag {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: var(--radius-full);
  font-weight: 500;
}
.status-in_progress {
  background: #dbeafe;
  color: #1d4ed8;
}
.status-not_started {
  background: #f3f4f6;
  color: #6b7280;
}
.status-completed {
  background: #d1fae5;
  color: #065f46;
}
.status-cancelled {
  background: #fee2e2;
  color: #991b1b;
}

/* 计划时间 */
.task-time {
  font-size: 22rpx;
  color: var(--color-text-muted);
  display: block;
  margin-bottom: 4rpx;
}

/* 进度点 */
.progress-dots {
  display: flex;
  align-items: center;
  gap: 5rpx;
  margin-top: 8rpx;
}
.dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: var(--color-border);
  transition: all 0.2s;
}
.dot-done {
  background: var(--color-primary);
}
.dot-today {
  border: 2rpx solid var(--color-primary);
  background: var(--color-white);
}
.progress-count {
  font-size: 22rpx;
  color: var(--color-warning);
  font-weight: 500;
  margin-left: 8rpx;
}
.edit-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--color-text-muted);
  padding: 0 var(--space-xs);
  flex-shrink: 0;
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}
.modal-body {
  background: var(--color-white);
  border-radius: var(--radius-xl);
  padding: 56rpx 48rpx;
  width: 640rpx;
  text-align: center;
  animation: scaleIn 0.4s ease;
}
.modal-emoji {
  font-size: 100rpx;
  display: block;
  margin-bottom: var(--space-md);
}
.modal-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  display: block;
  margin-bottom: var(--space-md);
}
.modal-streak {
  margin: var(--space-md) 0;
  display: flex;
  align-items: baseline;
  justify-content: center;
  gap: 6rpx;
}
.streak-num {
  font-size: 64rpx;
  font-weight: 700;
  color: var(--color-primary);
}
.streak-label {
  font-size: 28rpx;
  color: var(--color-text-muted);
}
.modal-tip {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  display: block;
  margin-bottom: var(--space-xl);
  line-height: 1.6;
}
